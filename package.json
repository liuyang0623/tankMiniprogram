{
  "name": "bailan-suibi",
  "version": "1.0.0",
  "description": "摆烂随笔 - 微信小程序",
  "private": true,
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass",
    "framework": "react"
  },
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:weapp:prod": "TARO_APP_ENV=prod taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "build:weapp:prod": "TARO_APP_ENV=prod taro build --type weapp",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc --noEmit"
  },
  "overrides": {
    "webpack": "5.91.0"
  },
  "resolutions": {
    "webpack": "5.91.0"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@fission-ai/openspec": "^1.5.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-generator": "4.2.0",
    "@tarojs/test-utils-react": "^0.1.1",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/react": "^18.3.1",
    "@types/webpack-env": "^1.18.5",
    "autoprefixer": "^10.4.20",
    "babel-preset-taro": "4.2.0",
    "postcss": "^8.4.47",
    "react-refresh": "^0.14.2",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "weapp-tailwindcss": "^3.7.0"
  }
