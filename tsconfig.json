{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "node",
    "removeComments": false,
    "preserveConstEnums": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "strict": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "rootDir": ".",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true,
    "types": ["@tarojs/taro", "react", "@types/webpack-env"],
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2020", "DOM"]
  },
  "include": ["./src", "./config", "./types", "./global.d.ts"],
  "exclude": ["node_modules", "dist"]
}
